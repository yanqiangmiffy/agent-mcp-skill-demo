# OpenAI SDK 兼容的对话运行时。
# 使用 OpenAI 官方 API 时，设置 OPENAI_API_KEY 并保留官方 /v1 地址。
# 使用兼容服务或本地模型时，设置对应的 /v1 地址和模型名。
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
MAX_STEPS=10

# 可选。留空时使用当前虚拟环境里的 Python 解释器。
PYTHON_EXECUTABLE=

# Agent 任务
SKILL_PATH=skills/oncall_holiday_check.md
DEFAULT_QUESTION=当前值班工程师所在国家今天是否有公共假日？如果有，列出他们名下的 P1 问题。

# MCP Server 配置
HOLIDAY_API_BASE=https://date.nager.at/api/v3
OPS_DB={root}/ops.db
