# OpenAI SDK-compatible chat runtime.
# For OpenAI, set OPENAI_API_KEY and use the official /v1 base URL.
# For compatible providers or local runtimes, set their /v1 base URL and model name.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
MAX_STEPS=10

# Optional. Leave empty to use the current virtualenv interpreter.
PYTHON_EXECUTABLE=

# Agent task
SKILL_PATH=skills/oncall_holiday_check.md
DEFAULT_QUESTION=当前值班工程师所在国家今天是否有公共假日？如果有，列出他们名下的 P1 问题。

# MCP server configuration
HOLIDAY_API_BASE=https://date.nager.at/api/v3
OPS_DB={root}/ops.db
